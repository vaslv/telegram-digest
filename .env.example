# ─────────────────────────────────────────────────────────────────────────────
# TelegramDigest configuration. Copy to `.env` and fill in the required values.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=json            # json | console
TIMEZONE=Europe/Moscow
DIGEST_LANGUAGE=ru

# ── Telegram (user account; get api_id/api_hash at https://my.telegram.org) ──
TG_API_ID=
TG_API_HASH=
TG_SESSION_PATH=/data/session/tgdigest
# Optional: paste a StringSession to skip the interactive `login` step.
# TG_STRING_SESSION=
# Optional: pre-fill for non-interactive login.
# TG_PHONE=+10000000000
# TG_2FA_PASSWORD=

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=tgdigest
POSTGRES_PASSWORD=tgdigest
POSTGRES_DB=tgdigest
POSTGRES_PORT=5432
# POSTGRES_HOST is set to `db` by docker-compose automatically.
# Or override everything with a single DSN:
# DATABASE_URL=postgresql+asyncpg://tgdigest:tgdigest@db:5432/tgdigest

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama        # ollama | openai | claude
LLM_MODEL=llama3.1:8b
LLM_BASE_URL=http://ollama:11434
# LLM_API_KEY=             # required for openai / claude
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1500
# LLM_CONTEXT_WINDOW=      # override the model registry if needed
LLM_REQUEST_TIMEOUT=120
LLM_MAX_RETRIES=4
# Optional: use a cheaper/faster model for stage 1 extraction.
# LLM_STAGE1_MODEL=
# LLM_STAGE2_MODEL=

# OpenAI-compatible example:
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# Claude example:
# LLM_PROVIDER=claude
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-haiku-4-5-20251001
# LLM_API_KEY=sk-ant-...

# ── Local preprocessing (noise reduction before the LLM) ─────────────────────
PRE_MERGE_GAP_SECONDS=90
PRE_MIN_MEANINGFUL_LEN=8
PRE_THREAD_GAP_MINUTES=30
PRE_DEDUP_WINDOW=50
# PRE_TRIVIAL_TOKENS=ок,окей,+,-,ага,спс,👍   # comma-separated stop tokens

# ── Web admin (http://localhost:8080) ────────────────────────────────────────
WEB_PASSWORD=change-me           # required to log in to the admin UI
WEB_SECRET_KEY=                  # random string for signed session cookies
WEB_PORT=8080
WEB_DIALOG_REFRESH_MINUTES=10    # how often the daemon refreshes the dialog cache
WEB_REQUEST_POLL_SECONDS=8       # how often the daemon runs queued digest requests

# ── Per-chat defaults applied by `watch-chat` ────────────────────────────────
DEFAULT_INTERVAL_MINUTES=180
DEFAULT_MIN_MSGS=10
DEFAULT_MAX_MSGS=300
DEFAULT_IMPORTANCE_THRESHOLD=0.5
DEFAULT_SEND_EMPTY=false
